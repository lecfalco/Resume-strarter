# Rename this file to .env before running the backend

# ── OpenAI ──────────────────────────────────────────────────────
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ── Database ─────────────────────────────────────────────────────
# Default: SQLite (file created automatically, no setup needed)
# To use PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/smarthire
DATABASE_URL=sqlite:///./smarthire.db
